# ============================================
# Shelf Life Estimator — Git Ignore
# ============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Virtual Environment ---
venv/
.venv/
env/

# --- Environment Variables ---
.env

# --- Database ---
*.db
*.sqlite3

# --- Uploads ---
uploads/*
!uploads/.gitkeep

# --- AI Models ---
models/*.h5
models/*.onnx
models/*.pb
models/*.tflite

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db

# --- Testing ---
.pytest_cache/
htmlcov/
.coverage

# --- Alembic ---
alembic/versions/*.pyc
