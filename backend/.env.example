# ============================================
# Shelf Life Estimator — Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME="Shelf Life Estimator"
APP_VERSION="1.0.0"
DEBUG=true

# --- Database ---
# SQLite (default for development)
DATABASE_URL=sqlite+aiosqlite:///./shelf_life.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/shelf_life

# --- CORS ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Security ---
SECRET_KEY=your-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- File Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# --- AI Models ---
CLASSIFIER_MODEL_PATH=models/food_classifier.h5
FRESHNESS_MODEL_PATH=models/freshness_assessor.h5
